# Instagram Automation - MyStrainAI
# Copy this to .env and fill in your values

# ── Meta / Instagram + Facebook Graph API ──
# See social/SETUP.md for how to get these
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Reddit API ──
# Create at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── App Configuration ──
APP_URL=https://mystrainai.com
APP_NAME=MyStrainAI
IG_HANDLE=@mystrainai

# ── Posting Schedule (cron expressions, ET timezone) ──
POST_1_CRON=0 11 * * *
POST_2_CRON=0 19 * * *
TIMEZONE=America/New_York

# ── Content Settings ──
# Directory where generated post images are saved
OUTPUT_DIR=./output
# Directory where screenshots are captured
SCREENSHOT_DIR=./screenshots
